[Unit]
Description=Koha background worker (default queue) for %i
PartOf=koha@%i.target
After=koha@%i.target

[Service]
Type=simple
User=%i-koha
Group=%i-koha
Environment=KOHA_CONF=/etc/koha/sites/%i/koha-conf.xml
Environment=PERL5LIB=/usr/share/koha/lib
ExecStart=/usr/share/koha/bin/workers/background_jobs_worker.pl --queue default
Restart=on-failure
RestartSec=5s
StartLimitBurst=3
StartLimitIntervalSec=60

[Install]
WantedBy=koha@%i.target
